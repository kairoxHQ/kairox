{
  "name": "kairox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Kairox paper-first trading-agent dashboard on Cloudflare Workers",
  "repository": {
    "type": "git",
    "url": "https://github.com/kairoxHQ/kairox.git"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:preview": "wrangler deploy --dry-run --outdir dist",
    "check": "tsc --noEmit",
    "build": "wrangler deploy --dry-run --outdir dist",
    "test": "node --test --experimental-strip-types tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260711.1",
    "typescript": "^5.9.0",
    "wrangler": "^4.24.0"
  }
}
